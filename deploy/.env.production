# mailrs production environment overrides
# values here override docker-compose.prod.yml defaults via docker compose --env-file
#
# IMPORTANT: deploy.sh SCPs this file as /apps/mailrs/.env every deploy,
# replacing whatever's there. ANY config the server needs that isn't a
# safe default in docker-compose.prod.yml MUST be in this file or it gets
# wiped on next deploy. (Discovery: v1.7.95-97 prod ran with
# MAILRS_HOSTNAME=mx.example.com placeholder because this file was empty
# of identity config — inbound silently broke for 13+ hours on 2026-06-03.
# v1.7.99 restores the full set.)

# --- mail server identity ---
MAILRS_HOSTNAME=mail.golia.ai
MAILRS_LOCAL_DOMAINS=golia.jp,golia.ai,dadaya.jp,marspot.com,bitreits.com,doracawl.com,madcawl.com

# --- TLS (certs live on the host filesystem, bind-mounted into the container) ---
MAILRS_TLS_CERT=/certs/fullchain.pem
MAILRS_TLS_KEY=/certs/privkey.pem

# --- auth ---
MAILRS_USERS_FILE=/data/users.toml

# --- DKIM signing ---
# Default signer (golia.jp): used when a sender's From: domain doesn't match
# an entry in MAILRS_DKIM_KEYS below.
MAILRS_DKIM_SELECTOR=mail
MAILRS_DKIM_DOMAIN=golia.jp
MAILRS_DKIM_PRIVATE_KEY=/dkim/golia.jp.key
# Per-domain DKIM overrides: signed `d=` is picked from the message's From:
# header. Without these, system mail (postmaster@<hostname>,
# noreply@<hostname>) from From-domain `mail.golia.ai` would sign
# d=golia.jp (the default) and DMARC-align-fail at receivers (e.g. Gmail).
# golia.ai + dadaya.jp share the golia.jp key (their DKIM public-key TXT
# records publish the same key). Splitting into per-domain key files is a
# future change; the same key works for all three until then.
MAILRS_DKIM_KEYS=golia.ai:mail:/dkim/golia.jp.key,dadaya.jp:mail:/dkim/golia.jp.key

# --- ACME / Let's Encrypt ---
# Account email — used for ACME registration + 30-day cert-expiry notifications.
# HOTFIX 2026-06-04: TEMPORARILY DISABLED.
# Reason: during the 13h MAILRS_HOSTNAME=mx.example.com drift, mailrs
# restarted ~5 times trying ACME challenge on the wrong hostname,
# tripping Let's Encrypt's "5 failed authorizations per identifier per
# hour" rate limit on mail.golia.ai. v1.7.99 first launch then panicked
# in bootstrap/tls.rs:58 on ACME 429.
# Manual TLS via /certs/{fullchain,privkey}.pem from the host bind mount
# is the active cert provider. Cert renewal cadence handled externally
# (next manual renewal due before /certs/ expiry ~2026-08-15).
# Re-enable AFTER the rate-limit window closes (now + 1h is safe) and
# only after testing with MAILRS_ACME_STAGING=true first to avoid
# burning more quota on production.
MAILRS_ACME_EMAIL=
MAILRS_ACME_DOMAINS=

# --- AI analysis ---
MAILRS_AI_ANALYSIS_ENABLED=false
MAILRS_LLM_URL=https://devops.golia.jp/api/llm/complete
MAILRS_LLM_API_KEY=

# --- webhook ---
MAILRS_WEBHOOK_URL=https://api.golia.jp/api/internal/mail-webhook

# --- antispam: SPF/DKIM/ARC/DMARC verification + DMARC policy enforcement ---
# enabled 2026-05-27 — was relying on upstream MX filtering; too much spam getting through.
# Now powered by mailrs-spf / mailrs-dkim / mailrs-arc / mailrs-dmarc (v1.7.31 cutover).
MAILRS_ANTISPAM_ENABLED=true
